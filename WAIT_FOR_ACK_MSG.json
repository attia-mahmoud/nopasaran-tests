{
  "id": "WAIT_FOR_ACK_MSG",
  "initial": "INIT",
  "states": {
    "INIT": {
      "on": {
        "STARTED": {
          "target": "GET_PARAMS"
        }
      }
    },
    "GET_PARAMS": {
      "entry": [
        {
          "type": "get_parameters (ctrl)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "WAIT_FOR_SYNC",
          "actions": {
            "type": "assign (ctrl)"
          }
        }
      }
    },
    "WAIT_FOR_SYNC": {
      "entry": [
        {
          "type": "set (4) (timeout)"
        },
        {
          "type": "wait_sync_signal (ctrl timeout) (ack)"
        }
      ],
      "on": {
        "SYNC_AVAILABLE": {
          "target": "END",
          "actions": [
            {
              "type": "assign (ctrl) (ctrl)"
            },
            {
              "type": "assign (ack) (ack)"
            },
            {
              "type": "assign (ACK_RECEIVED) (event)"
            }
          ]
        },
        "TIMEOUT": {
          "target": "END",
          "actions": [
            {
              "type": "assign (TIMEOUT) (event)"
            },
            {
              "type": "assign (0) (ack)"
            }
          ]
        }
      }
    },
    "END": {
      "entry": {
        "type": "return_values (ctrl event ip_dst)"
      }
    }
  }
}
