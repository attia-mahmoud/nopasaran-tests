{
  "id": "WAIT_FOR_ACK_MSG",
  "initial": "INIT",
  "states": {
    "INIT": {
      "on": {
        "STARTED": {
          "target": "GET_PARAMS"
        }
      }
    },
    "GET_PARAMS": {
      "entry": [
        {
          "type": "get_parameters (ctrl)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "WAIT_FOR_SYNC",
          "actions": {
            "type": "assign (ctrl) (ctrl)"
          }
        }
      }
    },
    "WAIT_FOR_SYNC": {
      "entry": [
        {
          "type": "set_integer (10) (timeout)"
        },
        {
          "type": "wait_sync_signal (ctrl timeout) (ack)"
        }
      ],
      "on": {
        "SYNC_AVAILABLE": {
          "target": "SYNC_RECEIVED"
        },
        "TIMEOUT": {
          "target": "TIMEOUT_ENDED"
        }
      }
    },
    "SYNC_RECEIVED": {
      "entry": [
        {
          "type": "set (ACK_RECEIVED) (event)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "END"
        }
      }
    },
    "TIMEOUT_ENDED": {
      "entry": [
        {
          "type": "set (TIMEOUT) (event)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "END"
        }
      }
    },
    "END": {
      "entry": {
        "type": "return_values (event)"
      }
    }
  }
}
