{
  "id": "SEND_PACKET",
  "initial": "INIT",
  "states": {
    "INIT": {
      "on": {
        "STARTED": {
          "target": "GET_PARAMS"
        }
      }
    },
    "GET_PARAMS": {
      "entry": [
        {
          "type": "get_parameters (ttl ip_dst)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "CREATE_PACKET",
          "actions": [
            {
              "type": "assign (ttl) (ttl)"
            },
            {
              "type": "assign (ip_dst) (ip_dst)"
            }
          ]
        }
      }
    },
    "CREATE_PACKET": {
      "entry": [
        {
          "type": "create_TCP_packet (pkt)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "MODIFY_PKT",
          "actions": [
            {
              "type": "assign (pkt) (pkt)"
            },
            {
              "type": "assign (ttl) (ttl)"
            },
            {
              "type": "assign (ip_dst) (ip_dst)"
            }
          ]
        }
      }
    },
    "MODIFY_PKT": {
      "entry": [
        {
          "type": "set_IP_ttl (pkt ttl) (pkt)"
        },
        {
          "type": "set_IP_dst (pkt ip_dst) (pkt)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "SEND_PACKET",
          "actions": {
            "type": "assign (pkt) (pkt)"
          }
        }
      }
    },
    "SEND_PACKET": {
      "entry": {
        "type": "send (pkt)"
      },
      "on": {
        "PACKET_SENT": {
          "target": "END"
        }
      }
    },
    "END": {
      "entry": [
        {
          "type": "set (PACKET_SENT) (event)"
        },
        {
          "type": "return_values (event)"
        }
      ]
    }
  }
}
