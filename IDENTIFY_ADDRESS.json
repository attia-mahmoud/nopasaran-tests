{
  "id": "IDENTIFY_ADDRESS",
  "initial": "INITIALIZATION STATE",
  "states": {
    "INITIALIZATION STATE": {
      "on": {
        "STARTING": {
          "target": "GET_PARAMS"
        }
      }
    },
    "GET_PARAMS": {
      "entry": [
        {
          "type": "get_parameters (ttl ip_dest filter)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "CREATE_PACKET",
          "actions": [
            {
              "type": "assign (ttl) (ttl)"
            },
            {
              "type": "assign (ip_dest) (ip_dest)"
            },
            {
              "type": "assign (filter) (filter)"
            }
          ]
        }
      }
    },
    "CREATE_PACKET": {
      "entry": [
        {
          "type": "create_TCP_packet (pkt)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "MODIFY_PKT",
          "actions": [
            {
              "type": "assign (pkt) (pkt)"
            },
            {
              "type": "assign (ttl) (ttl)"
            },
            {
              "type": "assign (ip_dest) (ip_dest)"
            },
            {
              "type": "assign (filter) (filter)"
            }
          ]
        }
      }
    },
    "MODIFY_PKT": {
      "entry": [
        {
          "type": "set_IP_ttl (pkt ttl) (pkt)"
        },
        {
          "type": "set_IP_dst (pkt ip_dest) (pkt)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "START_SNIFFER",
          "actions": [
            {
              "type": "assign (pkt) (pkt)"
            },
            {
              "type": "assign (filter) (filter)"
            }
          ]
        }
      }
    },
    "START_SNIFFER": {
      "entry": [
        {
          "type": "packet_filter (filter)"
        },
        {
          "type": "listen (queue)"
        },
        {
          "type": "set_integer (4) (timeout)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "SEND_PACKET",
          "actions": [
            {
              "type": "assign (queue) (queue)"
            },
            {
              "type": "assign (timeout) (timeout)"
            },
            {
              "type": "assign (pkt) (pkt)"
            }
          ]
        }
      }
    },
    "SEND_PACKET": {
      "entry": {
        "type": "send (pkt)"
      },
      "on": {
        "PACKET_SENT": {
          "target": "WAIT_FOR_PACKET",
          "actions": [
            {
              "type": "assign (queue) (queue)"
            },
            {
              "type": "assign (timeout) (timeout)"
            }
          ]
        }
      }
    },
    "WAIT_FOR_PACKET": {
      "entry": {
        "type": "wait_packet_signal (queue timeout)"
      },
      "on": {
        "TIMEOUT": {
          "target": "TIMEOUT_ENDED"
        },
        "PACKET_AVAILABLE": {
          "target": "HANDLE_REPLY",
          "actions": {
            "type": "assign (queue) (queue)"
          }
        }
      }
    },
    "TIMEOUT_ENDED": {
      "entry": [
        {
          "type": "set (TIMEOUT) (event)"
        },
        {
          "type": "set (0) (ip_dst)"
        },
        {
          "type": "set (0) (ip_src)"
        },
        {
          "type": "return_values (event ip_dst ip_src)"
        }
      ]
    },
    "HANDLE_REPLY": {
      "entry": [
        {
          "type": "get_first_element (queue) (reply)"
        },
        {
          "type": "get_IP_dst (reply) (ip_dst)"
        },
        {
          "type": "get_IP_src (reply) (ip_src)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "END",
          "actions": [
            {
              "type": "assign (ip_dst) (ip_dst)"
            },
            {
              "type": "assign (ip_src) (ip_src)"
            }
          ]
        }
      }
    },
    "END": {
      "entry": [
        {
          "type": "set (RESPONSE_RECEIVED) (event)"
        },
        {
          "type": "return_values (event ip_dst ip_src)"
        }
      ]
    }
  }
}
