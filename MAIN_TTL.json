{
  "id": "MAIN_TTL",
  "initial": "INITIALIZATION STATE",
  "states": {
    "INITIALIZATION STATE": {
      "on": {
        "STARTED": {
          "target": "SET_CONTROL_VARIABLES"
        }
      }
    },
    "SET_CONTROL_VARIABLES": {
      "entry": [
        {
          "type": "get_from_file (variables role) (role)"
        },
        {
          "type": "get_from_file (variables controller_conf_filename) (controller_conf_filename)"
        }
      ],
      "on": {
        "DONE": {
          "target": "SETUP_CONTROL_CHANNEL",
          "actions": [
            {
              "type": "assign (role) (role)"
            },
            {
              "type": "assign (controller_conf_filename) (controller_conf_filename)"
            }
          ]
        }
      }
    },
    "SETUP_CONTROL_CHANNEL": {
      "entry": [
        {
          "type": "call (CONTROL-CHANNEL-SETUP role controller_conf_filename) (event controller_protocol)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "CONTROL_CHANNEL_READY": {
          "target": "SET_PACKET_VARIABLES"
        },
        "TIMEOUT": {
          "target": "END"
        }
      }
    },
    "SET_PACKET_VARIABLES": {
      "entry": [
        {
          "type": "get_from_file (variables ttl) (ttl)"
        },
        {
          "type": "get_from_file (variables ip_dest) (ip_dest)"
        },
        {
          "type": "get_from_file (variables filter) (filter)"
        }
      ],
      "on": {
        "DONE": {
          "target": "CREATE_PACKET",
          "actions": [
            {
              "type": "assign (ttl) (ttl)"
            },
            {
              "type": "assign (ip_dest) (ip_dest)"
            },
            {
              "type": "assign (filter) (filter)"
            }
          ]
        }
      }
    },
    "END": {},
    "CREATE_PACKET": {
      "entry": [
        {
          "type": "create_TCP_packet (pkt)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "MODIFY_PKT",
          "actions": [
            {
              "type": "assign (pkt) (pkt)"
            },
            {
              "type": "assign (ttl) (ttl)"
            },
            {
              "type": "assign (ip_dest) (ip_dest)"
            },
            {
              "type": "assign (filter) (filter)"
            }
          ]
        }
      }
    },
    "MODIFY_PKT": {
      "entry": [
        {
          "type": "set_IP_ttl (pkt ttl) (pkt)"
        },
        {
          "type": "set_IP_dst (pkt ip_dest) (pkt)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "START_SNIFFER",
          "actions": [
            {
              "type": "assign (pkt) (pkt)"
            },
            {
              "type": "assign (filter) (filter)"
            }
          ]
        }
      }
    },
    "START_SNIFFER": {
      "entry": [
        {
          "type": "packet_filter (filter)"
        },
        {
          "type": "listen (queue)"
        },
        {
          "type": "set_integer (4) (timeout)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "SEND_PACKET",
          "actions": [
            {
              "type": "assign (queue) (queue)"
            },
            {
              "type": "assign (timeout) (timeout)"
            },
            {
              "type": "assign (pkt) (pkt)"
            }
          ]
        }
      }
    },
    "SEND_PACKET": {
      "entry": [
        {
          "type": "send (pkt)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "PACKET_SENT": {
          "target": "WAIT_FOR_PACKET",
          "actions": [
            {
              "type": "assign (queue) (queue)"
            },
            {
              "type": "assign (timeout) (timeout)"
            }
          ]
        }
      }
    },
    "WAIT_FOR_PACKET": {
      "entry": {
        "type": "wait_packet_signal (queue timeout)"
      },
      "on": {
        "TIMEOUT": {
          "target": "END"
        },
        "PACKET_AVAILABLE": {
          "target": "HANDLE_REPLY",
          "actions": {
            "type": "assign (queue) (queue)"
          }
        }
      }
    },
    "HANDLE_REPLY": {
      "entry": [
        {
          "type": "get_first_element (queue) (reply)"
        },
        {
          "type": "get_IP_dst (reply) (ip_dst)"
        },
        {
          "type": "get_IP_src (reply) (ip_src)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "END"
        }
      }
    }
  }
}
