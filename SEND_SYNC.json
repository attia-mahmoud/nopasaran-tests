{
  "id": "SEND_SYNC",
  "initial": "INIT",
  "states": {
    "INIT": {
      "on": {
        "STARTED": {
          "target": "GET_PARAMS"
        }
      }
    },
    "GET_PARAMS": {
      "entry": [
        {
          "type": "get_parameters (ctrl pkt)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "GET_ICMP_PAYLOAD",
          "actions": [
            {
              "type": "assign (ctrl) (ctrl)"
            },
            {
              "type": "assign (pkt) (pkt)"
            }
          ]
        }
      }
    },
    "GET_ICMP_PAYLOAD": {
      "entry": [
        {
          "type": "get_ICMP_payload (pkt) (payload)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "GET_PORT",
          "actions": [
            {
              "type": "assign (ctrl) (ctrl)"
            },
            {
              "type": "assign (payload) (payload)"
            }
          ]
        }
      }
    },
    "GET_PORT": {
      "entry": [
        {
          "type": "get_UDP_sport (payload) (port)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "GET_IP",
          "actions": [
            {
              "type": "assign (ctrl) (ctrl)"
            },
            {
              "type": "assign (payload) (payload)"
            },
            {
              "type": "assign (port) (port)"
            }
          ]
        }
      }
    },
    "GET_IP": {
      "entry": [
        {
          "type": "get_IP_src (payload) (ip)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "SEND_DATA",
          "actions": [
            {
              "type": "assign (ctrl) (ctrl)"
            },
            {
              "type": "assign (port) (port)"
            },
            {
              "type": "assign (ip) (ip)"
            }
          ]
        }
      }
    },
    "SEND_DATA": {
      "entry": {
        "type": "sync (ctrl ip port)"
      },
      "on": {
        "SYNC_SENT": {
          "target": "END"
        }
      }
    },
    "END": {
      "entry": [
        {
          "type": "set (SYNC_SENT) (event)"
        },
        {
          "type": "return_values (event)"
        }
      ]
    }
  }
}
