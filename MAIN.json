{
  "id": "MAIN",
  "initial": "INITIALIZATION STATE",
  "states": {
    "INITIALIZATION STATE": {
      "on": {
        "STARTED": {
          "target": "CREATE_CTRL_CHANNEL"
        }
      }
    },
    "CREATE_CTRL_CHANNEL": {
      "entry": [
        {
          "type": "call (CREATE_CONTROL_CHANNEL) (event ctrl role)"
        },
        {
          "type": "set (client) (client)"
        },
        {
          "type": "set (server) (server)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "CONTROL_CHANNEL_READY": [
          {
            "target": "GET_PACKET_VARS",
            "cond": "equal (role client)",
            "actions": {
              "type": "assign (ctrl) (ctrl)"
            }
          },
          {
            "target": "WAIT_FOR_MSG",
            "actions": {
              "type": "assign (ctrl) (ctrl)"
            }
          }
        ],
        "TIMEOUT": {
          "target": "END"
        }
      }
    },
    "GET_PACKET_VARS": {
      "entry": [
        {
          "type": "get_from_file (variables ttl) (ttl)"
        },
        {
          "type": "get_from_file (variables ip_dst) (ip_dst)"
        },
        {
          "type": "done"
        }
      ],
      "on": {
        "DONE": {
          "target": "SEND_FALSE_TTL_PKT",
          "actions": [
            {
              "type": "assign (ttl) (ttl)"
            },
            {
              "type": "assign (ip_dst) (ip_dst)"
            },
            {
              "type": "assign (ctrl) (ctrl)"
            }
          ]
        }
      }
    },
    "WAIT_FOR_MSG": {
      "entry": [
        {
          "type": "call (GET_SYNC ctrl) (event ip_dst)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "MESSAGE_RECEIVED": {
          "target": "SEND_SYNC_ACK",
          "actions": [
            {
              "type": "assign (ip_dst) (ip_dst)"
            },
            {
              "type": "assign (ctrl) (ctrl)"
            }
          ]
        },
        "TIMEOUT": {
          "target": "WAIT_FOR_MSG",
          "actions": {
            "type": "assign (ctrl) (ctrl)"
          }
        }
      }
    },
    "END": {},
    "SEND_FALSE_TTL_PKT": {
      "entry": [
        {
          "type": "call (SEND_PACKET ttl ip_dst) (event)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "PACKET_SENT": {
          "target": "SNIFF_ERROR_MSG",
          "actions": {
            "type": "assign (ctrl) (ctrl)"
          }
        }
      }
    },
    "SEND_SYNC_ACK": {
      "entry": [
        {
          "type": "call (SEND_ACK_MSG ctrl) (event)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "ACK_SENT": {
          "target": "SEND_PKT"
        }
      }
    },
    "SNIFF_ERROR_MSG": {
      "entry": [
        {
          "type": "get_from_file (variables icmp_filter) (filter)"
        },
        {
          "type": "call (SNIFF_PACKET filter) (event pkt)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "RESPONSE_RECEIVED": {
          "target": "SEND_SYNC_MSG",
          "actions": [
            {
              "type": "assign (pkt) (pkt)"
            },
            {
              "type": "assign (ctrl) (ctrl)"
            }
          ]
        },
        "TIMEOUT": {
          "target": "ICMP_ERROR_NOT_RECEIVED"
        }
      }
    },
    "SEND_PKT": {
      "entry": [
        {
          "type": "set (64) (ttl)"
        },
        {
          "type": "call (SEND_PACKET ttl ip_dst) (event)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "PACKET_SENT": {
          "target": "WAIT_FOR_UDP_ACK"
        }
      }
    },
    "SEND_SYNC_MSG": {
      "entry": [
        {
          "type": "call (SEND_SYNC ctrl pkt) (event)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "SYNC_SENT": {
          "target": "WAIT_FOR_SYNC_ACK",
          "actions": {
            "type": "assign (ctrl) (ctrl)"
          }
        }
      }
    },
    "ICMP_ERROR_NOT_RECEIVED": {},
    "WAIT_FOR_UDP_ACK": {
      "entry": [
        {
          "type": "call (WAIT_FOR_ACK_MSG ctrl) (event)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "ACK_RECEIVED": {
          "target": "END"
        }
      }
    },
    "WAIT_FOR_SYNC_ACK": {
      "entry": [
        {
          "type": "call (WAIT_FOR_ACK_MSG ctrl) (event)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "ACK_RECEIVED": {
          "target": "SNIFF_UDP_PKT"
        },
        "TIMEOUT": {
          "target": "END"
        }
      }
    },
    "SNIFF_UDP_PKT": {
      "entry": [
        {
          "type": "get_from_file (variables udp_filter) (filter)"
        },
        {
          "type": "call (SNIFF_PACKET filter) (event pkt)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "RESPONSE_RECEIVED": {
          "target": "SEND_UDP_ACK",
          "actions": {
            "type": "assign (ctrl) (ctrl)"
          }
        }
      }
    },
    "SEND_UDP_ACK": {
      "entry": [
        {
          "type": "call (SEND_ACK_MSG ctrl) (event)"
        },
        {
          "type": "trigger (event)"
        }
      ],
      "on": {
        "ACK_SENT": {
          "target": "END"
        }
      }
    }
  }
}
